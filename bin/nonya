#!/usr/bin/env python3
# nonya launcher — adds the repo root to sys.path and runs the package CLI.
# Cross-platform: works on macOS/Linux/WSL directly; on native Windows run
# `python -m nonya` (or use bin\nonya.cmd).
import os
import sys

_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
if _ROOT not in sys.path:
    sys.path.insert(0, _ROOT)

from nonya.cli import main  # noqa: E402

raise SystemExit(main())
